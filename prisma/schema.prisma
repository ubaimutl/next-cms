// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String?
  passwordHash String?
  role         UserRole  @default(EDITOR)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  posts        Post[]
  mediaAssets  MediaAsset[]
  passwordChangeTokens PasswordChangeToken[]
  sessions     Session[]
}

model Post {
  id            Int     @id @default(autoincrement())
  title         String
  slug          String  @unique
  content       String? @db.Text
  featuredImage String?
  seoTitle      String?
  seoDescription String? @db.Text
  seoImage      String?
  published     Boolean @default(false)
  authorId      Int
  author        User    @relation(fields: [authorId], references: [id])
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userAgentHash String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([lastSeenAt])
}

model PasswordChangeToken {
  id                  Int      @id @default(autoincrement())
  tokenHash           String   @unique
  pendingPasswordHash String
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime @default(now())
  userId              Int
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AuthRateLimit {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  failures      Int      @default(0)
  firstFailedAt DateTime @default(now())
  lastFailedAt  DateTime @default(now())
  blockedUntil  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([blockedUntil])
  @@index([updatedAt])
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  tags        Json
  images      Json
  link        String?
}

model ShopProduct {
  id           Int             @id @default(autoincrement())
  title        String
  slug         String          @unique
  summary      String          @db.Text
  content      String?         @db.Text
  seoTitle     String?
  seoDescription String?       @db.Text
  seoImage     String?
  priceCents   Int
  currency     String          @default("EUR")
  kind         ShopProductKind @default(SERVICE)
  active       Boolean         @default(true)
  availability ShopAvailability @default(AVAILABLE)
  requiresBrief Boolean        @default(false)
  briefPrompt  String?         @db.Text
  deliveryText String?
  highlights   Json
  images       Json
  orders       ShopOrder[]
}

model ShopOrder {
  id              Int             @id @default(autoincrement())
  productId       Int
  product         ShopProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  status          ShopOrderStatus @default(PENDING)
  paypalOrderId   String          @unique
  paypalCaptureId String?         @unique
  amountCents     Int
  currency        String
  buyerEmail      String?
  buyerName       String?
  buyerBrief      String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([productId])
  @@index([status, createdAt])
}

model ContactMessage {
  id          Int                  @id @default(autoincrement())
  name        String
  email       String
  company     String?
  website     String?
  services    Json
  budget      String?
  timeline    String?
  message     String               @db.Text
  status      ContactMessageStatus @default(NEW)
  emailSentAt DateTime?
  emailError  String?              @db.Text
  readAt      DateTime?
  createdAt   DateTime             @default(now())

  @@index([status, createdAt])
  @@index([createdAt])
}

model AnalyticsSettings {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalyticsPageView {
  id           Int      @id @default(autoincrement())
  path         String
  postSlug     String?
  visitorToken String
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([postSlug])
  @@index([visitorToken])
}

model AppSettings {
  id              Int      @id @default(1)
  blogEnabled     Boolean  @default(true)
  projectsEnabled Boolean  @default(true)
  shopEnabled     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MediaAsset {
  id           Int           @id @default(autoincrement())
  url          String        @unique
  pathname     String        @unique
  provider     MediaProvider
  kind         MediaKind
  mimeType     String
  size         Int
  uploadedById Int?
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([kind, createdAt])
  @@index([uploadedById])
}

enum ContactMessageStatus {
  NEW
  READ
  ARCHIVED
}

enum ShopProductKind {
  SERVICE
  DIGITAL
}

enum ShopAvailability {
  AVAILABLE
  COMING_SOON
  SOLD_OUT
}

enum ShopOrderStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
}

enum MediaProvider {
  BLOB
  LOCAL
}

enum MediaKind {
  POST_IMAGE
  PROJECT_IMAGE
  PRODUCT_IMAGE
}
